@page "/upload"
@using BasicSheets.Shared.Services
@using BasicSheets.Shared.Models;
@inject SheetService SheetService;
@inject NavigationManager navigationManager;

<PageTitle>Noten hinzufügen</PageTitle>

<div class="main-container-large">
    <div class="upload-card">

        <div class="file-zone @(selectedFile != null ? "file-zone-ok" : "")">
            <InputFile OnChange="OnFileSelected" accept=".pdf" id="pdf-input" />
            <label for="pdf-input" class="file-zone-label">
                @if (selectedFile != null)
                {
                    <span class="file-chosen">📄 @selectedFile.Name</span>
                }
                else
                {
                    <span class="file-hint">PDF auswählen</span>
                }
            </label>
        </div>

        @if (fileError != null)
        {
            <p class="field-error">@fileError</p>
        }

        <div class="form-group">
            <label class="field-label">Name *</label>
            <input class="field-input" placeholder="Name der Note" @bind="sheet.Name" />
        </div>
        <div class="form-group">
            <label class="field-label">Komponist</label>
            <input class="field-input" placeholder="Komponist" @bind="sheet.Composer" />
        </div>
        <div class="form-group">
            <label class="field-label">Stimme / Instrument</label>
            <input class="field-input" placeholder="z.B. Geige, Klavier …" @bind="sheet.Part" />
        </div>

        <button class="submit-btn" @onclick="SaveSheet"
                disabled="@(selectedFile == null || string.IsNullOrWhiteSpace(sheet.Name) || isUploading)">
            @if (isUploading) { <span>Wird gespeichert…</span> }
            else              { <span>Hinzufügen</span> }
        </button>

    </div>
</div>

@code {
    private Sheet sheet = new();
    private IBrowserFile? selectedFile;
    private string? fileError;
    private bool isUploading;
    private static readonly Random Rng = new();
    private const long MaxFileSize = 30L * 1024 * 1024;

    private bool IsPdf(IBrowserFile f) =>
        f.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ||
        f.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase);

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        fileError = IsPdf(selectedFile) ? null : "Bitte eine PDF-Datei auswählen.";
    }

    private static string RandomName() =>
        new string(Enumerable.Repeat("abcdefghijklmnopqrstuvwxyz0123456789", 20)
            .Select(s => s[Rng.Next(s.Length)]).ToArray());

    private async Task SaveSheet()
    {
        if (selectedFile == null || string.IsNullOrWhiteSpace(sheet.Name)) return;
        if (!IsPdf(selectedFile)) { fileError = "Bitte eine PDF-Datei auswählen."; return; }
        if (selectedFile.Size > MaxFileSize) { fileError = "Datei zu groß (max. 30 MB)."; return; }

        isUploading = true;
        StateHasChanged();

        try
        {
            string fileName = RandomName() + ".pdf";
            string folder = Path.Combine(AppContext.BaseDirectory, "wwwroot", "uploads");
            Directory.CreateDirectory(folder);
            string filePath = Path.Combine(folder, fileName);

            using var fs = new FileStream(filePath, FileMode.Create);
            await selectedFile.OpenReadStream(MaxFileSize).CopyToAsync(fs);

            sheet.FilePath = $"uploads/{fileName}";
            SheetService.AddSheets(sheet);
            navigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            fileError = $"Fehler beim Speichern: {ex.Message}";
            isUploading = false;
        }
    }
}
