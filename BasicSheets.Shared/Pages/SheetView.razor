@layout BasicSheets.Shared.Layout.MainLayoutClean
@using BasicSheets.Shared.Services
@page "/sheets/{file}"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject SettingsService SettingsService
@implements IDisposable

@if (showUi)
{
    <div class="viewer-header">
        <button class="hdr-btn" @onclick="GoBack" title="Zurück">
            <img src="/_content/BasicSheets.Shared/icons/arrow.svg" class="hdr-icon" />
        </button>
    </div>

    @if (pageCount > 1)
    {
        <div class="slider-bar">
            <span class="page-label">@currentPage / @pageCount</span>
            <input type="range" min="1" max="@pageCount" @bind="currentPage" @oninput="OnSlider" class="range" />
        </div>
    }
}

@if (showUi && !isEditMode)
{
    <div class="viewer-header-right">
        <button class="hdr-btn" @onclick="TakeNotes" title="Annotieren">
            <img src="/_content/BasicSheets.Shared/icons/edit.svg" class="hdr-icon" />
        </button>
    </div>
}
else if (isEditMode)
{
    <div class="viewer-header-right">
        <button class="hdr-btn hdr-btn-cancel" @onclick="TakeNotes" title="Fertig">
            <img src="/_content/BasicSheets.Shared/icons/cancel.svg" class="hdr-icon" />
        </button>
    </div>

    <div class="annotation-toolbar">
        <div class="tool-row">
            <button class="@ToolClass("pen")" @onclick='() => SetTool("pen")' title="Stift">
                <img src="/_content/BasicSheets.Shared/icons/pen.svg" class="tbr-icon @(activeTool == "pen" ? "tbr-icon-active" : "")" />
            </button>
            <button class="@ToolClass("marker")" @onclick='() => SetTool("marker")' title="Marker">
                <img src="/_content/BasicSheets.Shared/icons/marker.svg" class="tbr-icon @(activeTool == "marker" ? "tbr-icon-active" : "")" />
            </button>
            <button class="@ToolClass("eraser")" @onclick='() => SetTool("eraser")' title="Radierer">
                <img src="/_content/BasicSheets.Shared/icons/eraser.svg" class="tbr-icon @(activeTool == "eraser" ? "tbr-icon-active" : "")" />
            </button>
            <button class="@ToolClass("text")" @onclick='() => SetTool("text")' title="Text">
                <span class="tbr-symbol">T</span>
            </button>

            <div class="tool-divider"></div>

            <button class="@ToolClass("flat")" @onclick='() => SetTool("flat")' title="Be">
                <span class="tbr-symbol music">♭</span>
            </button>
            <button class="@ToolClass("sharp")" @onclick='() => SetTool("sharp")' title="Kreuz">
                <span class="tbr-symbol music">♯</span>
            </button>
            <button class="@ToolClass("natural")" @onclick='() => SetTool("natural")' title="Auflösung">
                <span class="tbr-symbol music">♮</span>
            </button>
            <button class="@ToolClass("double-flat")" @onclick='() => SetTool("double-flat")' title="Doppel-Be">
                <span class="tbr-symbol music sm">𝄫</span>
            </button>
            <button class="@ToolClass("double-sharp")" @onclick='() => SetTool("double-sharp")' title="Doppel-Kreuz">
                <span class="tbr-symbol music sm">𝄪</span>
            </button>
            <button class="@ToolClass("fermata")" @onclick='() => SetTool("fermata")' title="Fermate">
                <span class="tbr-symbol music sm">𝄐</span>
            </button>
            <button class="@ToolClass("trill")" @onclick='() => SetTool("trill")' title="Triller">
                <span class="tbr-symbol sm">tr</span>
            </button>

            <div class="tool-divider"></div>

            <button class="@ToolClass("crescendo")" @onclick='() => SetTool("crescendo")' title="Crescendo (ziehen)">
                <img src="/_content/BasicSheets.Shared/icons/crescendo.svg" class="tbr-icon @(activeTool == "crescendo" ? "tbr-icon-active" : "")" />
            </button>
            <button class="@ToolClass("decrescendo")" @onclick='() => SetTool("decrescendo")' title="Decrescendo (ziehen)">
                <img src="/_content/BasicSheets.Shared/icons/decrescendo.svg" class="tbr-icon @(activeTool == "decrescendo" ? "tbr-icon-active" : "")" />
            </button>

            <div class="tool-divider"></div>

            <button class="tool-btn action-btn" @onclick="Undo" title="Rückgängig">
                <img src="/_content/BasicSheets.Shared/icons/arrow.svg" class="tbr-icon" />
            </button>
            <button class="tool-btn action-btn redo-btn" @onclick="Redo" title="Wiederholen">
                <img src="/_content/BasicSheets.Shared/icons/arrow.svg" class="tbr-icon" />
            </button>
            <button class="tool-btn action-btn" @onclick="ClearPage" title="Seite löschen">
                <img src="/_content/BasicSheets.Shared/icons/delete.svg" class="tbr-icon" />
            </button>
        </div>

        <div class="options-row">
            <div class="color-picker">
                @foreach (var c in PenColors)
                {
                    <button class="color-swatch @(activeColor == c ? "color-swatch-active" : "")"
                            style="background:@c" @onclick="() => SetColor(c)"></button>
                }
            </div>

            @if (!IsStampTool)
            {
                <div class="size-picker">
                    <button class="size-btn @(activeSize == 1 ? "size-active" : "")" @onclick='() => SetSize(1)'>S</button>
                    <button class="size-btn @(activeSize == 2 ? "size-active" : "")" @onclick='() => SetSize(2)'>M</button>
                    <button class="size-btn @(activeSize == 3 ? "size-active" : "")" @onclick='() => SetSize(3)'>L</button>
                </div>
            }
        </div>
    </div>
}

@if (showTextInput)
{
    <div class="text-overlay" @onclick="CancelText">
        <div class="text-box" style="left:@(ClampX(textScreenX))px; top:@(ClampY(textScreenY))px"
             @onclick:stopPropagation="true">
            <input @bind="textValue" @bind:event="oninput"
                   placeholder="Text eingeben…"
                   @onkeydown="OnTextKey"
                   autofocus />
            <button class="text-ok" @onclick="ConfirmText">✓</button>
        </div>
    </div>
}

<div class="viewer-page" @onclick="HandleClick">
    @if (showStart) { <div class="show-info"><p>Anfang des Stücks</p></div> }
    @if (showEnd)   { <div class="show-info"><p>Ende des Stücks</p></div> }
    @if (showError)
    {
        <div class="error-message"><p>@errorMessage</p></div>
    }
    else
    {
        <div id="viewer">
            <canvas id="noteCanvas"></canvas>
            <canvas id="pdfCanvas"></canvas>
        </div>
    }
</div>

@code {
    [Parameter] public string? file { get; set; }

    private int currentPage = 1;
    private int pageCount = 1;
    private bool showUi = true;
    private bool showStart, showEnd, showError;
    private string errorMessage = "";
    private bool isEditMode;
    private bool enableHandleClick = true;

    private string activeTool = "pen";
    private string activeColor = "#000000";
    private int activeSize = 2;

    private bool showTextInput;
    private double textCanvasX, textCanvasY, textScreenX, textScreenY;
    private string textValue = "";

    private DotNetObjectReference<SheetView>? _ref;

    private static readonly string[] PenColors = { "#000000", "#E53935", "#1E88E5", "#43A047", "#FB8C00", "#8E24AA" };
    private static readonly string[] StampTools = { "flat", "sharp", "natural", "double-flat", "double-sharp", "fermata", "trill", "segno", "coda", "text" };
    private static readonly int[] SizeMap = { 1, 3, 6 };

    private bool IsStampTool => StampTools.Contains(activeTool);
    private string ToolClass(string t) => "tool-btn" + (activeTool == t ? " tool-active" : "");
    private double ClampX(double x) => Math.Max(4, Math.Min(x, 260));
    private double ClampY(double y) => Math.Max(4, Math.Min(y, 500));

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;

        _ref = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("setPdfDotNetRef", _ref);
        await JS.InvokeVoidAsync("initCanvas", "pdfCanvas", "noteCanvas");

        try
        {
            string filePath = Path.Combine(AppContext.BaseDirectory, "wwwroot", "uploads", file!);
            byte[] pdfBytes = await File.ReadAllBytesAsync(filePath);

            if (SettingsService.TwoPageLayout())
            {
                pageCount = await JS.InvokeAsync<int>("loadPdfData", file, pdfBytes) - 1;
                await JS.InvokeVoidAsync("renderTwoPage", 1);
            }
            else
            {
                pageCount = await JS.InvokeAsync<int>("loadPdfData", file, pdfBytes);
                await JS.InvokeVoidAsync("renderPage", 1);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            showError = true;
            errorMessage = $"Fehler beim Laden: {ex.Message}";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void ShowTextInput(double canvasX, double canvasY, double screenX, double screenY)
    {
        textCanvasX = canvasX;
        textCanvasY = canvasY;
        textScreenX = screenX;
        textScreenY = screenY;
        showTextInput = true;
        StateHasChanged();
    }

    private async Task OnTextKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ConfirmText();
        else if (e.Key == "Escape") CancelText();
    }

    private async Task ConfirmText()
    {
        if (!string.IsNullOrWhiteSpace(textValue))
        {
            int px = SizeMap[activeSize - 1] * 8;
            await JS.InvokeVoidAsync("drawTextOnCanvas", textCanvasX, textCanvasY, textValue, activeColor, px);
        }
        showTextInput = false;
        textValue = "";
    }

    private void CancelText() { showTextInput = false; textValue = ""; }

    private async Task OnSlider(ChangeEventArgs e)
    {
        currentPage = int.Parse(e.Value!.ToString()!);
        await RenderCurrent();
    }

    private async Task RenderCurrent()
    {
        if (SettingsService.TwoPageLayout())
            await JS.InvokeVoidAsync("renderTwoPage", currentPage);
        else
            await JS.InvokeVoidAsync("renderPage", currentPage);
    }

    private async Task HandleClick(MouseEventArgs e)
    {
        if (!enableHandleClick) return;
        double x = e.ClientX;
        double w = await JS.InvokeAsync<double>("getWindowWidth");

        if (x < w * 0.35 && currentPage > 1)
        {
            currentPage--;
            await RenderCurrent();
        }
        else if (x > w * 0.65 && currentPage < pageCount)
        {
            currentPage++;
            await RenderCurrent();
        }
        else if (x < w * 0.35 && currentPage == 1)
        {
            if (!SettingsService.startAndEndHints()) return;
            showStart = true; StateHasChanged();
            await Task.Delay(2000);
            showStart = false; StateHasChanged();
        }
        else if (x > w * 0.65 && currentPage == pageCount)
        {
            if (!SettingsService.startAndEndHints()) return;
            showEnd = true; StateHasChanged();
            await Task.Delay(2000);
            showEnd = false; StateHasChanged();
        }
        else
        {
            showUi = !showUi;
            StateHasChanged();
        }
    }

    private void GoBack() => Nav.NavigateTo("/");

    private void TakeNotes()
    {
        isEditMode = !isEditMode;
        JS.InvokeVoidAsync("setEditMode", isEditMode);
        showUi = !isEditMode;
        enableHandleClick = !isEditMode;
    }

    private void SetTool(string t) { activeTool = t; JS.InvokeVoidAsync("setTool", t); }

    private void SetColor(string c) { activeColor = c; JS.InvokeVoidAsync("setColor", c); }

    private void SetSize(int s) { activeSize = s; JS.InvokeVoidAsync("setPenSize", SizeMap[s - 1]); }

    private void Undo()      => JS.InvokeVoidAsync("undoNote");
    private void Redo()      => JS.InvokeVoidAsync("redoNote");
    private void ClearPage() => JS.InvokeVoidAsync("clearNotes");

    public void Dispose() => _ref?.Dispose();
}
