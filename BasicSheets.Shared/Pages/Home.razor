@page "/"
@using BasicSheets.Shared.Services
@using BasicSheets.Shared.Models;
@inject SheetService SheetService;
@inject NavigationManager navigationManager;
@inject IJSRuntime JsRuntime

<PageTitle>BasicSheets</PageTitle>

<div class="search-container">
    <input placeholder="Suchen …" @bind="searchText" @bind:event="oninput" />
    <select @bind="selectedField">
        <option value="all">Alle</option>
        <option value="Name">Name</option>
        <option value="Composer">Komponist</option>
        <option value="Part">Stimme</option>
    </select>
</div>

<div class="main-container">
    @if (FilteredSheets.Count > 0)
    {
        @foreach (Sheet sheet in FilteredSheets)
        {
            <div class="sheet-card" @onclick="() => OpenSheet(sheet)">
                <div class="sheet-card-inner">
                    <div class="sheet-info">
                        <h3 class="sheet-name">@sheet.Name</h3>
                        @if (!string.IsNullOrWhiteSpace(sheet.GetInformation()))
                        {
                            <p class="sheet-meta">@sheet.GetInformation()</p>
                        }
                    </div>
                    <div class="sheet-actions">
                        <button class="act-btn act-edit"
                                @onclick="() => OpenEdit(sheet)"
                                @onclick:stopPropagation="true"
                                title="Bearbeiten">
                            <img class="act-icon" src="/_content/BasicSheets.Shared/icons/edit.svg" />
                        </button>
                        <button class="act-btn act-delete"
                                @onclick="() => DeleteSheet(sheet)"
                                @onclick:stopPropagation="true"
                                title="Löschen">
                            <img class="act-icon" src="/_content/BasicSheets.Shared/icons/delete.svg" />
                        </button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <p class="empty-title">Noch keine Noten</p>
            <p class="empty-sub">Tippe auf + um eine PDF hinzuzufügen</p>
        </div>
    }
</div>

@code {
    string searchText = "";
    string selectedField = "all";

    private List<Sheet> FilteredSheets
    {
        get
        {
            var sheets = SheetService.GetSheets();
            if (string.IsNullOrWhiteSpace(searchText)) return sheets;
            return sheets.Where(s =>
            {
                if (selectedField == "all")
                    return s.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                        || s.Composer.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                        || s.Part.Contains(searchText, StringComparison.OrdinalIgnoreCase);
                var prop = s.GetType().GetProperty(selectedField);
                var val = prop?.GetValue(s)?.ToString();
                return val != null && val.Contains(searchText, StringComparison.OrdinalIgnoreCase);
            }).ToList();
        }
    }

    private async Task DeleteSheet(Sheet sheet)
    {
        bool ok = await JsRuntime.InvokeAsync<bool>("confirm", $"{sheet.Name} wirklich loeschen?");
        if (!ok) return;
        SheetService.RemoveSheets(sheet);
        navigationManager.Refresh();
    }

    private void OpenSheet(Sheet sheet) =>
        navigationManager.NavigateTo($"/sheets/{Path.GetFileName(sheet.FilePath)}");

    private void OpenEdit(Sheet sheet) =>
        navigationManager.NavigateTo($"/edit/{Path.GetFileName(sheet.FilePath)}");
}
